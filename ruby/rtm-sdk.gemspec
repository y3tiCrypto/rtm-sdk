Gem::Specification.new do |s|
  s.name        = 'rtm-sdk'
  s.version     = '1.0.0'
  s.summary     = 'Official Ruby SDK for Raptoreum (RTM) JSON-RPC API'
  s.description = 'A simple, zero-dependency client for connecting to a Raptoreum Core node.'
  s.authors     = ['Raptoreum Developers']
  s.email       = 'dev@raptoreum.com'
  s.files       = ['lib/raptoreum.rb']
  s.homepage    = 'https://github.com/Raptor3um/rtm-sdk'
  s.license     = 'MIT'
  s.required_ruby_version = '>= 2.5'
end
